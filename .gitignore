# 行情原始数据缓存（每日由 fetch_klines.sh 重新拉取，无需入库）
scripts/raw/
.DS_Store
__pycache__/
*.tmp
# Hermes hook 更新日志（本机运行日志，不入库）
scripts/.hermes-update.log
scripts/raw_news.json
# 跨语言数据锁（运行时产物，不入库）
.data.lock

# Mac 原生 App 构建产物（不入库）
app/stock-dashboard
股市看板.app/
app/icon_assets/AppIcon.iconset/

# 个人持仓配置与衍生分析（可能包含真实财务数据，不入库）
portfolio.json
holdings.js
portfolio_analysis.js
portfolio_signals.js

# 小红书卡片生成临时文件
xhs/output/
xhs/*.png
.refresh.lock
node_modules/
# 环境变量/密钥文件，防误提交
.env
.env.*
playwright-report/
test-results/
_site/
