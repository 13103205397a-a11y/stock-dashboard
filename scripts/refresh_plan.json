{
  "version": 2,
  "description": "本地全量刷新计划。app_server.py、Mac App 和命令行统一读取此文件。",
  "steps": [
    {
      "name": "抓日K(腾讯)",
      "command": ["bash", "scripts/fetch_klines.sh"],
      "timeout": 300,
      "required": true
    },
    {
      "name": "算技术信号",
      "command": ["node", "scripts/fetch_signals.js"],
      "timeout": 300,
      "required": true
    },
    {
      "name": "抓新闻(东方财富)",
      "command": ["python3", "scripts/fetch_news.py"],
      "timeout": 300,
      "required": false
    },
    {
      "name": "补资金/研报/估值",
      "command": ["python3", "scripts/fetch_enhanced.py"],
      "timeout": 300,
      "required": false
    },
    {
      "name": "全市场异动",
      "command": ["python3", "scripts/fetch_market.py"],
      "timeout": 300,
      "required": true
    },
    {
      "name": "行业板块排行",
      "command": ["python3", "scripts/fetch_industry.py"],
      "timeout": 300,
      "required": false
    },
    {
      "name": "全量新闻/公告",
      "command": ["python3", "scripts/fetch_news_all.py"],
      "timeout": 300,
      "required": false
    },
    {
      "name": "今日热点TOP30",
      "command": ["python3", "scripts/fetch_hot.py"],
      "timeout": 600,
      "required": false,
      "requiresEnv": "IWENCAI_API_KEY"
    },
    {
      "name": "同步持仓行情",
      "command": ["python3", "scripts/fetch_holdings.py"],
      "timeout": 300,
      "required": false,
      "localPrivate": true
    },
    {
      "name": "同步Hermes复盘",
      "command": ["python3", "scripts/fetch_hermes.py"],
      "timeout": 300,
      "required": false,
      "localOnly": true
    },
    {
      "name": "同步持仓分析",
      "command": ["python3", "scripts/fetch_portfolio_analysis.py"],
      "timeout": 300,
      "required": false,
      "localPrivate": true
    },
    {
      "name": "同步周末发酵",
      "command": ["python3", "scripts/fetch_weekend.py"],
      "timeout": 300,
      "required": false,
      "localOnly": true
    },
    {
      "name": "校验公开数据契约",
      "command": ["node", "scripts/validate_data.js"],
      "timeout": 60,
      "required": true
    }
  ]
}
